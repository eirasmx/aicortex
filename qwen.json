  // wait on the same promise (_registryReady).

  let _registry = null;           // null = not loaded, Array = loaded
  let _registryReady = null;      // Promise<void> — shared fetch in-flight
  let _registryFetchedAt = 0;     // monotonic ms timestamp of last successful fetch
  let _registryTTL = 60 * 60 * 1000;  // 1 hour — configurable via AICortex.registryTTL

  // ─── Persistent cache (localStorage / Node fs) ───────────────────────────────

  const _CACHE_KEY    = 'aicortex_registry';
