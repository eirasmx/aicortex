   * GitHub raw is the upstream truth, and npm CDN (jsDelivr) is an extra mirror.
   *
   * Each source is a function that takes a family name and returns a URL string.
   */
  const _REMOTE_SOURCES = [
    fam => `https://unpkg.com/aicortex/models/${fam}.json`,
    fam => `https://raw.githubusercontent.com/eirasmx/aicortex/main/web/models/${fam}.json`,
    fam => `https://cdn.jsdelivr.net/npm/aicortex/models/${fam}.json`,
