   * Force a module-level registry refresh (useful in scripts/tests).
   * @returns {Promise<void>}
   */
  AICortex.refreshRegistry = async function () {
    _registry = null;
    _registryFetchedAt = 0;
    _registryReady = null;
    await _ensureRegistry();
  };

  return AICortex;
}));
