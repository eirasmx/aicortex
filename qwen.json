        ? _getRegistry().filter(e => e.model === model)
        : _getRegistry();
      return [...entries].sort((a, b) => (b.tps || 0) - (a.tps || 0));
    }

    /**
     * Get the best available server for a model.
     * @param {string} [model]
     * @returns {{url, model, tps, city, country} | null}
     */
