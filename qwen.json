   *   - whole registry: fresh fetch → persistent cache → empty (throws if no servers found)
   */
  async function _buildLiveRegistry() {
    // 1. Get the family index (which families exist remotely)
    let families = null;
    const indexData = await _fetchJsonMirrors(_FAMILY_INDEX_SOURCES);
    if (Array.isArray(indexData)) families = indexData;

