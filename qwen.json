  /** Fetch from multiple mirror URLs, return first success or null. */
  async function _fetchJsonMirrors(urlFns, ...args) {
    for (const fn of urlFns) {
      const data = await _fetchJson(fn(...args));
      if (data) return data;
    }
    return null;
  }

  // ─── Registry bootstrap ───────────────────────────────────────────────────────

  /**
   * Build the live registry by fetching all known families in parallel.
   * Falls back gracefully at every step:
